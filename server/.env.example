PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=1d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Use exact origin(s), comma separated. Do not use '*'
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123
NODE_ENV=development
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
SHUTDOWN_TIMEOUT_MS=10000
# Optional: set this when backend should serve frontend build files itself.
# CLIENT_DIST_PATH=../client/dist
